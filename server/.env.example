# 🔧 LOCAL DEVELOPMENT (.env file)
NODE_ENV=development
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/campus-auth?retryWrites=true&w=majority
PORT=4000
CLIENT_URL=http://localhost:3000
RP_ID=localhost
RP_NAME=CampusAuth
JWT_SECRET=dev-secret-key-change-in-production-12345

# 🔧 PRODUCTION DEPLOYMENT (.env.production file)
# NODE_ENV=production
# MONGO_URI=mongodb+srv://YOUR_USER:YOUR_PASS@YOUR_CLUSTER.mongodb.net/campus-auth?retryWrites=true&w=majority
# CLIENT_URL=https://your-vercel-app.vercel.app
# RP_ID=your-vercel-app.vercel.app
# JWT_SECRET=use-a-strong-random-string-here
