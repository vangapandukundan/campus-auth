MONGO_URI=mongodb://localhost:27017/campus_auth
JWT_SECRET=your_jwt_secret_here
PORT=4000

# For local dev, keep this as localhost
# For production (Render), set this to https://campus-auth.vercel.app
CLIENT_URL=http://localhost:3000

# WebAuthn origin — must match exactly where your frontend runs
# Local:       http://localhost:3000
# Production:  https://campus-auth.vercel.app
WEBAUTHN_ORIGIN=http://localhost:3000
WEBAUTHN_RP_ID=localhost
